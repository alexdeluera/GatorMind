# Ignore everything
*

# Allow CelebA folder
!CelebA/

# Allow metadata
!CelebA/metadata.json
!CelebA/subset_attributes.json.json

# Allow cluster sets
!CelebA/set_01/
!CelebA/set_01/paths.json
!CelebA/set_01/centroids.json

# Allow subset images
!CelebA/images/
!CelebA/images/*.jpg

# Allow CatDog folder
!CatDog/

# Allow metadata
!CatDog/metadata.json

# Allow cluster sets
!CatDog/set_01/
!CatDog/set_01/paths.json
!CatDog/set_01/centroids.json

# Allow subset images
!CatDog/images/
!CatDog/images/*.jpg

# Keep .gitignore itself
!.gitignore